# ============================================
# CosmoGuru CRM — Cloud Function Environment
# Copy this to .env and fill in your values
# ============================================

# Google Sheets
SPREADSHEET_ID=your_spreadsheet_id_here

# WATI (WhatsApp)
WATI_TENANT_ID=your_tenant_id
WATI_BEARER_TOKEN=your_bearer_token
WATI_BASE_URL=https://live-mt-server.wati.io/

# Firebase RTDB (for whitelist — separate from Firestore)
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com/
FIREBASE_SECRET=your_firebase_secret

# Smartflo (calling)
SMARTFLO_API_KEY=your_smartflo_api_key
SMARTFLO_CONTACT_GROUP_ID=your_contact_group_id

# Firestore (CRM database)
# Firestore auto-detects credentials on GCP, no key needed
# Set to 'false' to disable Firestore writes (kill switch)
FIRESTORE_ENABLED=true

# Phase control: 1 = Sheet-first (parallel write), 2 = Firestore-first
FIRESTORE_PHASE=2

# Multi-Spreadsheet (Phase 3) — Outbound sync targets
# SHEET_AGENTS_ID defaults to SPREADSHEET_ID if not set
SHEET_AGENTS_ID=your_agents_spreadsheet_id
SHEET_SALES_ID=your_sales_spreadsheet_id
SHEET_PAYMENTS_ID=your_payments_spreadsheet_id
SHEET_DELIVERY_ID=your_delivery_spreadsheet_id
SHEET_MASTER_ID=your_master_spreadsheet_id

# Google Auth (local dev only — not needed on GCP)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
